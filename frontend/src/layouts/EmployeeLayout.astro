---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fichar - Mi Panel">
  <div class="employee-layout">
    <header class="header">
      <div class="header-left">
        <h1 class="logo">Fichar</h1>
        <span class="badge">Empleado</span>
      </div>
      <div class="header-right">
        <span class="user-name" id="user-name">Usuario</span>
        <a href="/logout" class="logout-btn">Cerrar Sesión</a>
      </div>
    </header>

    <nav class="nav">
      <a href="/employee" class="nav-item" data-section="dashboard">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <span>Mi Estado</span>
      </a>
      
      <a href="/employee/history" class="nav-item" data-section="history">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        <span>Historial</span>
      </a>
      
      <a href="/employee/monthly" class="nav-item" data-section="monthly">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="20" x2="18" y2="10"></line>
          <line x1="12" y1="20" x2="12" y2="4"></line>
          <line x1="6" y1="20" x2="6" y2="14"></line>
        </svg>
        <span>Resumen Mensual</span>
      </a>
      
      <a href="/employee/reports" class="nav-item" data-section="reports">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        <span>Mis Reportes</span>
      </a>
    </nav>
    
    <main class="main-content">
      <slot />
    </main>
  </div>
</Layout>

<script>
  import { auth } from '../config/api';

  document.addEventListener('DOMContentLoaded', () => {
    // Check authentication - only employees allowed
    if (!auth.isAuthenticated() || auth.isAdmin()) {
      window.location.href = '/login';
      return;
    }

    // Set user info
    const user = auth.getUser();
    if (user) {
      const nameEl = document.getElementById('user-name');
      if (nameEl) nameEl.textContent = `${user.first_name} ${user.last_name}`;
    }

    // Active nav link
    const currentPath = window.location.pathname;
    const navItems = document.querySelectorAll('.nav-item');
    navItems.forEach(item => {
      const href = item.getAttribute('href');
      if (currentPath === href || (href !== '/employee' && currentPath.startsWith(href))) {
        item.classList.add('active');
      }
    });
  });
</script>

<style>
  .employee-layout {
    min-height: 100vh;
    background: #f8fafc;
  }

  .header {
    background: white;
    padding: 1rem 2rem;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1e293b;
    margin: 0;
  }

  .badge {
    background: #10b981;
    color: white;
    font-size: 0.625rem;
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    text-transform: uppercase;
    font-weight: 600;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-name {
    font-weight: 600;
    color: #1e293b;
  }

  .logout-btn {
    color: #ef4444;
    text-decoration: none;
    font-size: 0.875rem;
  }

  .logout-btn:hover {
    text-decoration: underline;
  }

  .nav {
    background: white;
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    border-bottom: 1px solid #e5e7eb;
    overflow-x: auto;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    color: #64748b;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    transition: all 0.15s;
  }

  .nav-item:hover {
    background: #f1f5f9;
    color: #1e293b;
  }

  .nav-item.active {
    background: #3b82f6;
    color: white;
  }

  .main-content {
    padding: 2rem;
  }

  @media (max-width: 640px) {
    .nav {
      padding: 0.75rem 1rem;
    }
    
    .nav-item span {
      display: none;
    }
  }
</style>