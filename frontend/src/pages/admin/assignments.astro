---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="page">
    <header class="page-header">
      <div>
        <h1 class="page-title">Asignaciones de turno</h1>
        <p class="page-subtitle">Asignar turnos a empleados</p>
      </div>
      <button class="btn btn-primary" id="add-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nueva asignación
      </button>
    </header>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Empleado</th>
            <th>Turno</th>
            <th>Fecha inicio</th>
            <th>Fecha fin</th>
          </tr>
        </thead>
        <tbody id="assignments-tbody">
          <tr><td colspan="4" class="loading-cell">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="modal-overlay" id="modal">
    <div class="modal" role="dialog" aria-labelledby="modal-title">
      <header class="modal-header">
        <h2 class="modal-title" id="modal-title">Nueva asignación</h2>
        <button class="modal-close" id="close-modal" aria-label="Cerrar">&times;</button>
      </header>
      <form id="assignment-form" class="modal-form">
        <div class="form-group">
          <label for="employee_id">Empleado</label>
          <select id="employee_id" required></select>
        </div>

        <div class="form-group">
          <label for="shift_id">Turno</label>
          <select id="shift_id" required></select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="start_date">Fecha inicio</label>
            <input type="date" id="start_date" required />
          </div>
          <div class="form-group">
            <label for="end_date">Fecha fin</label>
            <input type="date" id="end_date" />
          </div>
        </div>

        <footer class="modal-actions">
          <button type="button" class="btn btn-secondary" id="cancel-btn">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </footer>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { api, auth } from '../../config/api';

  const modal = document.getElementById('modal');
  const form = document.getElementById('assignment-form') as HTMLFormElement;
  const tbody = document.getElementById('assignments-tbody');
  const employeeSelect = document.getElementById('employee_id') as HTMLSelectElement;
  const shiftSelect = document.getElementById('shift_id') as HTMLSelectElement;

  let employees: any[] = [];
  let shifts: any[] = [];

  async function loadData() {
    const token = auth.getToken();
    if (!token) return;

    try {
      [employees, shifts] = await Promise.all([api.getEmployees(token), api.getShifts(token)]);

      employeeSelect.innerHTML = employees.map(e => `<option value="${e.id}">${e.first_name} ${e.last_name}</option>`).join('');
      shiftSelect.innerHTML = shifts.map(s => `<option value="${s.id}">${s.name}</option>`).join('');

      await loadAssignments();
    } catch (e) {
      tbody.innerHTML = `<tr><td colspan="4" class="error-cell">Error al cargar datos</td></tr>`;
    }
  }

  async function loadAssignments() {
    const token = auth.getToken();
    if (!token) return;

    try {
      const allAssignments = [];
      for (const emp of employees) {
        const assignments = await api.getEmployeeShifts(token, emp.id);
        for (const a of assignments) {
          const shift = shifts.find(s => s.id === a.shift_id);
          a.employee_name = `${emp.first_name} ${emp.last_name}`;
          a.shift_name = shift?.name || '-';
          allAssignments.push(a);
        }
      }

      if (allAssignments.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="empty-cell">No hay asignaciones</td></tr>`;
      } else {
        tbody.innerHTML = allAssignments.map(a => `
          <tr>
            <td>${a.employee_name}</td>
            <td>${a.shift_name}</td>
            <td>${a.start_date}</td>
            <td>${a.end_date || '<span class="badge badge-success">Activo</span>'}</td>
          </tr>
        `).join('');
      }
    } catch (e) {
      tbody.innerHTML = `<tr><td colspan="4" class="error-cell">Error al cargar asignaciones</td></tr>`;
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = auth.getToken();
    if (!token) return;

    const endDate = (document.getElementById('end_date') as HTMLInputElement).value || undefined;

    try {
      await api.assignShift(token, {
        employee_id: employeeSelect.value,
        shift_id: shiftSelect.value,
        start_date: (document.getElementById('start_date') as HTMLInputElement).value,
        end_date: endDate,
      });
      closeModal();
      await loadAssignments();
    } catch (err: any) { alert(err.message || 'Error'); }
  });

  function openModal() {
    modal.classList.add('active');
  }

  function closeModal() {
    modal.classList.remove('active');
    form.reset();
  }

  document.getElementById('add-btn').addEventListener('click', openModal);
  document.getElementById('close-modal').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  loadData();
</script>
