---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="page">
    <header class="page-header">
      <div>
        <h1 class="page-title">Empleados</h1>
        <p class="page-subtitle">Gestionar empleados del sistema</p>
      </div>
      <button class="btn btn-primary" id="add-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo empleado
      </button>
    </header>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>DNI</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Rol</th>
            <th>Hs/día</th>
            <th>Hs/mes</th>
            <th aria-label="Acciones"></th>
          </tr>
        </thead>
        <tbody id="employees-tbody">
          <tr><td colspan="7" class="loading-cell">Cargando…</td></tr>
        </tbody>
      </table>
    </div>

    <div class="alert alert-danger" id="error" hidden></div>
  </div>

  <div class="modal-overlay" id="modal">
    <div class="modal" role="dialog" aria-labelledby="modal-title">
      <header class="modal-header">
        <h2 class="modal-title" id="modal-title">Nuevo empleado</h2>
        <button class="modal-close" id="close-modal" aria-label="Cerrar">&times;</button>
      </header>
      <form id="employee-form" class="modal-form">
        <input type="hidden" id="employee-id" />

        <div class="form-group">
          <label for="dni">DNI</label>
          <input type="text" id="dni" name="dni" required pattern="[0-9]+" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="first_name">Nombre</label>
            <input type="text" id="first_name" name="first_name" required />
          </div>
          <div class="form-group">
            <label for="last_name">Apellido</label>
            <input type="text" id="last_name" name="last_name" required />
          </div>
        </div>

        <div class="form-group">
          <label for="role">Rol</label>
          <select id="role" name="role">
            <option value="EMPLOYEE">Empleado</option>
            <option value="ADMIN">Administrador</option>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="daily_hours">Horas diarias</label>
            <input type="number" id="daily_hours" name="daily_hours" min="1" max="24" step="0.5" value="8" />
          </div>
          <div class="form-group">
            <label for="monthly_hours">Horas mensuales</label>
            <input type="number" id="monthly_hours" name="monthly_hours" min="1" max="744" step="1" value="160" />
          </div>
        </div>

        <footer class="modal-actions">
          <button type="button" class="btn btn-secondary" id="cancel-btn">Cancelar</button>
          <button type="submit" class="btn btn-primary" id="submit-btn">Guardar</button>
        </footer>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { api, auth } from '../../config/api';

  const modal = document.getElementById('modal');
  const form = document.getElementById('employee-form') as HTMLFormElement;
  const tbody = document.getElementById('employees-tbody');

  let employees: any[] = [];

  async function loadEmployees() {
    const token = auth.getToken();
    if (!token) {
      window.location.href = '/login';
      return;
    }

    try {
      employees = await api.getEmployees(token);
      renderTable();
    } catch (e) {
      console.error('Error:', e);
      tbody.innerHTML = `<tr><td colspan="7" class="error-cell">Error al cargar empleados</td></tr>`;
    }
  }

  function renderTable() {
    if (employees.length === 0) {
      tbody.innerHTML = `<tr><td colspan="7" class="empty-cell">No hay empleados</td></tr>`;
      return;
    }

    tbody.innerHTML = employees.map(emp => `
      <tr>
        <td><code>${emp.dni}</code></td>
        <td>${emp.first_name}</td>
        <td>${emp.last_name}</td>
        <td><span class="badge ${emp.role.toLowerCase()}">${emp.role === 'ADMIN' ? 'Admin' : 'Empleado'}</span></td>
        <td>${emp.daily_hours || 8}</td>
        <td>${emp.monthly_hours || 160}</td>
        <td>
          <div class="actions">
            <button class="btn-icon is-edit" data-id="${emp.id}" title="Editar" aria-label="Editar">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </button>
            <button class="btn-icon is-delete" data-id="${emp.id}" title="Eliminar" aria-label="Eliminar">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    tbody.querySelectorAll('.is-edit').forEach(btn => {
      btn.addEventListener('click', () => editEmployee(btn.getAttribute('data-id')));
    });
    tbody.querySelectorAll('.is-delete').forEach(btn => {
      btn.addEventListener('click', () => deleteEmployee(btn.getAttribute('data-id')));
    });
  }

  function openModal(emp?: any) {
    const title = document.getElementById('modal-title');
    const idInput = document.getElementById('employee-id') as HTMLInputElement;
    const dniInput = document.getElementById('dni') as HTMLInputElement;
    const firstInput = document.getElementById('first_name') as HTMLInputElement;
    const lastInput = document.getElementById('last_name') as HTMLInputElement;
    const roleSelect = document.getElementById('role') as HTMLSelectElement;

    if (emp) {
      title.textContent = 'Editar empleado';
      idInput.value = emp.id;
      dniInput.value = emp.dni;
      firstInput.value = emp.first_name;
      lastInput.value = emp.last_name;
      roleSelect.value = emp.role;
      (document.getElementById('daily_hours') as HTMLInputElement).value = (emp.daily_hours || 8).toString();
      (document.getElementById('monthly_hours') as HTMLInputElement).value = (emp.monthly_hours || 160).toString();
      dniInput.disabled = true;
    } else {
      title.textContent = 'Nuevo empleado';
      form.reset();
      idInput.value = '';
      dniInput.disabled = false;
      (document.getElementById('daily_hours') as HTMLInputElement).value = '8';
      (document.getElementById('monthly_hours') as HTMLInputElement).value = '160';
    }

    modal.classList.add('active');
  }

  function closeModal() {
    modal.classList.remove('active');
  }

  function editEmployee(id: string | null) {
    const emp = employees.find(e => e.id === id);
    if (emp) openModal(emp);
  }

  async function deleteEmployee(id: string | null) {
    if (!confirm('¿Eliminar este empleado?')) return;

    const token = auth.getToken();
    if (!token) return;

    try {
      await api.deleteEmployee(token, id);
      await loadEmployees();
    } catch (e) {
      alert('Error al eliminar empleado');
    }
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = auth.getToken();
    if (!token) return;

    const id = (document.getElementById('employee-id') as HTMLInputElement).value;
    const dailyHours = parseFloat((document.getElementById('daily_hours') as HTMLInputElement).value) || 8;
    const monthlyHours = parseFloat((document.getElementById('monthly_hours') as HTMLInputElement).value) || 160;

    const data = {
      dni: (document.getElementById('dni') as HTMLInputElement).value,
      first_name: (document.getElementById('first_name') as HTMLInputElement).value,
      last_name: (document.getElementById('last_name') as HTMLInputElement).value,
      role: (document.getElementById('role') as HTMLSelectElement).value,
      daily_hours: dailyHours,
      monthly_hours: monthlyHours,
    };

    try {
      if (id) {
        await api.updateEmployee(token, id, data);
      } else {
        await api.createEmployee(token, data);
      }
      closeModal();
      await loadEmployees();
    } catch (e: any) {
      alert(e.message || 'Error al guardar');
    }
  });

  document.getElementById('add-btn').addEventListener('click', () => openModal());
  document.getElementById('close-modal').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  loadEmployees();
</script>

<style>
  code {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    background: var(--color-surface-2);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
  }
</style>
