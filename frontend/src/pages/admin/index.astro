---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="page">
    <header class="page-header">
      <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Resumen del sistema hoy</p>
      </div>
    </header>

    <div class="stats-grid" id="stats-grid" hidden>
      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-employees">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <div class="stat-label">Total empleados</div>
        </div>
        <div class="stat-value" id="total-employees">—</div>
      </div>

      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-present">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="stat-label">Presentes hoy</div>
        </div>
        <div class="stat-value" id="present-today">—</div>
      </div>

      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-absent">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
            </svg>
          </div>
          <div class="stat-label">Ausentes hoy</div>
        </div>
        <div class="stat-value" id="absent-today">—</div>
      </div>

      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-late">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="stat-label">Llegadas tarde</div>
        </div>
        <div class="stat-value" id="late-today">—</div>
      </div>

      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-hours">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="stat-label">Horas totales</div>
        </div>
        <div class="stat-value" id="total-hours">—</div>
      </div>

      <div class="stat-card">
        <div class="stat-row">
          <div class="stat-icon icon-overtime">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          </div>
          <div class="stat-label">Horas extra</div>
        </div>
        <div class="stat-value" id="overtime-hours">—</div>
      </div>
    </div>

    <div class="state" id="loading">
      <span class="spinner spinner-lg" aria-hidden="true"></span>
      <p>Cargando datos…</p>
    </div>

    <div class="alert alert-danger" id="error" hidden>
      Error al cargar datos. Verificá la conexión.
    </div>
  </div>
</AdminLayout>

<script>
  import { api, auth } from '../../config/api';

  const loading = document.getElementById('loading');
  const error = document.getElementById('error');
  const statsGrid = document.getElementById('stats-grid');

  async function loadDashboard() {
    const token = auth.getToken();
    if (!token) {
      window.location.href = '/login';
      return;
    }

    try {
      const data = await api.getDashboardSummary(token);

      document.getElementById('total-employees').textContent = data.total_employees.toString();
      document.getElementById('present-today').textContent = data.present_today.toString();
      document.getElementById('absent-today').textContent = data.absent_today.toString();
      document.getElementById('late-today').textContent = data.late_arrivals_today.toString();
      document.getElementById('total-hours').textContent = data.total_worked_hours.toFixed(1);
      document.getElementById('overtime-hours').textContent = data.total_overtime_hours.toFixed(1);

      loading.hidden = true;
      statsGrid.hidden = false;
    } catch (e) {
      console.error('Error loading dashboard:', e);
      loading.hidden = true;
      error.hidden = false;
    }
  }

  loadDashboard();
</script>

<style>
  .stat-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .stat-icon {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .icon-employees { background: var(--color-info-bg); color: var(--color-info-fg); }
  .icon-present   { background: var(--color-success-bg); color: var(--color-success-fg); }
  .icon-absent    { background: var(--color-danger-bg); color: var(--color-danger-fg); }
  .icon-late      { background: var(--color-warning-bg); color: var(--color-warning-fg); }
  .icon-hours     { background: var(--color-accent-soft); color: var(--color-accent); }
  .icon-overtime  { background: #fce7f3; color: #be185d; }

  .stat-card .stat-label {
    margin-bottom: 0;
    text-transform: none;
    letter-spacing: var(--tracking-tight);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .stat-card .stat-value {
    font-variant-numeric: tabular-nums;
  }
</style>
