---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="page">
    <header class="page-header">
      <div>
        <h1 class="page-title">Reportes</h1>
        <p class="page-subtitle">Consultar informes del sistema</p>
      </div>
    </header>

    <div class="tabs">
      <button class="tab-btn active" data-tab="dashboard">Resumen</button>
      <button class="tab-btn" data-tab="attendance">Asistencia</button>
      <button class="tab-btn" data-tab="late">Tardanzas</button>
      <button class="tab-btn" data-tab="overtime">Horas extra</button>
      <button class="tab-btn" data-tab="special">Informe especial</button>
    </div>

    <div class="filters" id="filters">
      <div class="filter-group">
        <label for="start-date">Desde</label>
        <input type="date" id="start-date" value="2026-04-01" />
      </div>
      <div class="filter-group">
        <label for="end-date">Hasta</label>
        <input type="date" id="end-date" value="2026-04-30" />
      </div>
      <div class="filter-group employee-filter" hidden>
        <label for="employee-filter">Empleado</label>
        <select id="employee-filter">
          <option value="">Todos</option>
        </select>
      </div>
      <button class="btn btn-primary" id="apply-filters">Aplicar</button>
    </div>

    <div id="report-content">
      <div class="state"><span class="spinner spinner-lg"></span><p>Cargando…</p></div>
    </div>
  </div>

  <div class="modal-overlay" id="correction-modal">
    <div class="modal" role="dialog" aria-labelledby="correction-title">
      <header class="modal-header">
        <h2 class="modal-title" id="correction-title">Corregir asistencia</h2>
        <button class="modal-close" id="close-correction" aria-label="Cerrar">&times;</button>
      </header>
      <form id="correction-form" class="modal-form">
        <input type="hidden" id="correction-attendance-id" />

        <div class="form-group">
          <label for="correction-date">Fecha</label>
          <input type="date" id="correction-date" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="correction-checkin">Hora de entrada</label>
            <input type="time" id="correction-checkin" required />
          </div>
          <div class="form-group">
            <label for="correction-checkout">Hora de salida</label>
            <input type="time" id="correction-checkout" required />
          </div>
        </div>

        <div class="form-group">
          <label for="correction-reason">Motivo de corrección</label>
          <textarea id="correction-reason" rows="3" required placeholder="Ej: Empleado olvidó registrar salida"></textarea>
        </div>

        <footer class="modal-actions">
          <button type="button" class="btn btn-secondary" id="cancel-correction">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar corrección</button>
        </footer>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { api, auth } from '../../config/api';

  const tabs = document.querySelectorAll('.tab-btn');
  const content = document.getElementById('report-content');
  const employeeFilter = document.getElementById('employee-filter') as HTMLSelectElement;
  const filterContainer = document.querySelector('.employee-filter') as HTMLElement;

  let currentTab = 'dashboard';
  let employees: any[] = [];

  async function init() {
    const token = auth.getToken();
    if (!token) return;

    employees = await api.getEmployees(token);
    employeeFilter.innerHTML = `<option value="">Todos</option>` +
      employees.map(e => `<option value="${e.id}">${e.first_name} ${e.last_name}</option>`).join('');

    loadReport();
  }

  async function loadReport() {
    const token = auth.getToken();
    if (!token) return;

    const startDate = (document.getElementById('start-date') as HTMLInputElement).value;
    const endDate = (document.getElementById('end-date') as HTMLInputElement).value;
    const empFilter = employeeFilter.value;

    content.innerHTML = '<div class="state"><span class="spinner spinner-lg"></span><p>Cargando…</p></div>';

    try {
      switch (currentTab) {
        case 'dashboard':
          filterContainer.hidden = true;
          const dash = await api.getDashboardSummary(token);
          content.innerHTML = renderDashboard(dash);
          break;

        case 'attendance':
          filterContainer.hidden = false;
          const att = await api.getAttendanceReport(token, startDate, endDate, empFilter || undefined);
          attendanceData = att;
          content.innerHTML = renderTable('Asistencia', ['Fecha', 'Empleado', 'DNI', 'Entrada', 'Salida', 'Horas', 'Estado'],
            att.length ? att.map(r => [r.date, r.employee_name, r.dni, r.check_in || '-', r.check_out || '-', r.worked_hours.toFixed(1), r.is_late ? 'Tarde' : 'Normal', r.id || '', r.corrected || false]) : []);
          break;

        case 'late':
          filterContainer.hidden = true;
          const late = await api.getLateArrivalsReport(token, startDate, endDate);
          content.innerHTML = renderTable('Tardanzas', ['Fecha', 'Empleado', 'DNI', 'Entrada', 'Minutos tarde'],
            late.length ? late.map(r => [r.date, r.employee_name, r.dni, r.check_in, r.late_minutes.toString()]) : []);
          break;

        case 'overtime':
          filterContainer.hidden = false;
          const ot = await api.getOvertimeReport(token, startDate, endDate, empFilter || undefined);
          content.innerHTML = renderTable('Horas extra', ['Fecha', 'Empleado', 'DNI', 'Horas trab.', 'Horas extra'],
            ot.length ? ot.map(r => [r.date, r.employee_name, r.dni, r.worked_hours.toFixed(1), r.overtime_hours.toFixed(1)]) : []);
          break;

        case 'special':
          filterContainer.hidden = true;
          content.innerHTML = renderSpecialReportForm();
          break;
      }
    } catch (e: any) {
      content.innerHTML = `<div class="alert alert-danger">Error: ${e.message}</div>`;
    }
  }

  function renderDashboard(data: any): string {
    return `
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-label">Total empleados</div><div class="stat-value">${data.total_employees}</div></div>
        <div class="stat-card"><div class="stat-label">Presentes hoy</div><div class="stat-value">${data.present_today}</div></div>
        <div class="stat-card"><div class="stat-label">Ausentes hoy</div><div class="stat-value">${data.absent_today}</div></div>
        <div class="stat-card"><div class="stat-label">Tardanzas hoy</div><div class="stat-value">${data.late_arrivals_today}</div></div>
        <div class="stat-card"><div class="stat-label">Horas totales</div><div class="stat-value">${data.total_worked_hours.toFixed(1)}</div></div>
        <div class="stat-card"><div class="stat-label">Horas extra</div><div class="stat-value">${data.total_overtime_hours.toFixed(1)}</div></div>
      </div>
    `;
  }

  function renderTable(title: string, headers: string[], rows: any[][]): string {
    if (rows.length === 0) return `<div class="state">Sin datos para el período seleccionado</div>`;

    const isAttendanceTable = currentTab === 'attendance';

    return `
      <div class="table-wrap">
        <table class="table">
          <thead><tr>${headers.map(h => `<th>${h}</th>`).join('')}${isAttendanceTable ? '<th aria-label="Acciones"></th>' : ''}</tr></thead>
          <tbody>${rows.map((r, idx) => {
            if (isAttendanceTable) {
              const isCorrected = r[7] === true;
              const stateBadge = r[6] === 'Tarde'
                ? `<span class="badge badge-warning">Tarde</span>`
                : `<span class="badge badge-success">Normal</span>`;
              return `<tr>
                <td>${r[0]}</td><td>${r[1]}</td><td><code>${r[2]}</code></td><td>${r[3]}</td><td>${r[4]}</td><td>${r[5]}</td><td>${stateBadge}</td>
                <td><div class="actions">
                  <button class="btn-icon correct-btn" data-idx="${idx}" title="Corregir" aria-label="Corregir">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                  </button>
                  ${isCorrected ? '<span class="badge badge-success" title="Corregido">✓</span>' : ''}
                </div></td>
              </tr>`;
            }
            return `<tr>${r.map(c => `<td>${c}</td>`).join('')}</tr>`;
          }).join('')}</tbody>
        </table>
      </div>
    `;
  }

  function renderSpecialReportForm(): string {
    const today = new Date().toISOString().split('T')[0];
    const firstOfMonth = today.substring(0, 7) + '-01';

    return `
      <div class="card">
        <div class="form-group">
          <label for="special-employee">Empleado</label>
          <select id="special-employee" required>
            <option value="">Seleccionar empleado…</option>
            ${employees.map(e => `<option value="${e.id}">${e.first_name} ${e.last_name}</option>`).join('')}
          </select>
        </div>

        <div class="form-group" style="margin-top: var(--space-4);">
          <label for="special-header">Encabezado (opcional)</label>
          <input type="text" id="special-header" placeholder="Ej: Certificado de trabajo" />
        </div>

        <div class="form-group" style="margin-top: var(--space-4);">
          <label for="special-text">Texto del informe</label>
          <textarea id="special-text" rows="4" required placeholder="Escribí el texto que aparecerá en el informe…"></textarea>
        </div>

        <div class="checkbox-grid">
          <label class="checkbox-group"><input type="checkbox" id="include-days" />Incluir días trabajados</label>
          <label class="checkbox-group"><input type="checkbox" id="include-hours" />Incluir horas trabajadas</label>
          <label class="checkbox-group"><input type="checkbox" id="include-months" />Incluir meses del periodo</label>
          <label class="checkbox-group"><input type="checkbox" id="include-period" checked />Incluir periodo del informe</label>
        </div>

        <div class="form-row" style="margin-top: var(--space-4);">
          <div class="form-group">
            <label for="special-start">Fecha desde</label>
            <input type="date" id="special-start" value="${firstOfMonth}" />
          </div>
          <div class="form-group">
            <label for="special-end">Fecha hasta</label>
            <input type="date" id="special-end" value="${today}" />
          </div>
        </div>

        <div style="margin-top: var(--space-5);">
          <button type="button" class="btn btn-primary" id="generate-special-report">Generar PDF</button>
        </div>

        <div id="special-report-status"></div>
      </div>
    `;
  }

  document.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    if (target.id === 'generate-special-report') {
      const employeeId = (document.getElementById('special-employee') as HTMLSelectElement).value;
      const header = (document.getElementById('special-header') as HTMLInputElement).value;
      const customText = (document.getElementById('special-text') as HTMLTextAreaElement).value;
      const includeDays = (document.getElementById('include-days') as HTMLInputElement).checked;
      const includeHours = (document.getElementById('include-hours') as HTMLInputElement).checked;
      const includeMonths = (document.getElementById('include-months') as HTMLInputElement).checked;
      const includePeriod = (document.getElementById('include-period') as HTMLInputElement).checked;
      const startDate = (document.getElementById('special-start') as HTMLInputElement).value;
      const endDate = (document.getElementById('special-end') as HTMLInputElement).value;

      const statusDiv = document.getElementById('special-report-status');

      if (!employeeId) {
        statusDiv.innerHTML = '<div class="alert alert-danger" style="margin-top: var(--space-4);">Debe seleccionar un empleado</div>';
        return;
      }

      if (!customText) {
        statusDiv.innerHTML = '<div class="alert alert-danger" style="margin-top: var(--space-4);">Debe escribir el texto del informe</div>';
        return;
      }

      statusDiv.innerHTML = '<div class="state"><span class="spinner"></span><p>Generando informe…</p></div>';

      try {
        const token = auth.getToken();
        if (!token) return;

        const blob = await api.generateSpecialReport(
          token, employeeId, header, customText,
          includeDays, includeHours, includeMonths, includePeriod,
          startDate, endDate
        );

        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `informe_especial.pdf`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);

        statusDiv.innerHTML = '<div class="alert alert-success" style="margin-top: var(--space-4);">Informe generado correctamente</div>';
      } catch (err: any) {
        statusDiv.innerHTML = `<div class="alert alert-danger" style="margin-top: var(--space-4);">Error: ${err.message}</div>`;
      }
    }
  });

  let attendanceData: any[] = [];

  const correctionModal = document.getElementById('correction-modal');
  const correctionForm = document.getElementById('correction-form') as HTMLFormElement;

  function openCorrectionModal(attendanceId: string, date: string, checkIn: string, checkOut: string) {
    (document.getElementById('correction-attendance-id') as HTMLInputElement).value = attendanceId;
    (document.getElementById('correction-date') as HTMLInputElement).value = date;

    if (checkIn && checkIn !== '-') {
      const inTime = checkIn.split('T')[1] || checkIn.split(' ')[1];
      if (inTime) (document.getElementById('correction-checkin') as HTMLInputElement).value = inTime.substring(0, 5);
    }
    if (checkOut && checkOut !== '-') {
      const outTime = checkOut.split('T')[1] || checkOut.split(' ')[1];
      if (outTime) (document.getElementById('correction-checkout') as HTMLInputElement).value = outTime.substring(0, 5);
    }

    (document.getElementById('correction-reason') as HTMLTextAreaElement).value = '';
    correctionModal.classList.add('active');
  }

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest('.correct-btn') as HTMLElement | null;
    if (btn) {
      const idx = parseInt(btn.getAttribute('data-idx') || '0');
      const att = attendanceData[idx];
      if (att) {
        openCorrectionModal(att.id, att.date, att.check_in || '', att.check_out || '');
      }
    }
  });

  function closeCorrectionModal() {
    correctionModal.classList.remove('active');
  }

  correctionForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = auth.getToken();
    if (!token) return;

    const attendanceId = (document.getElementById('correction-attendance-id') as HTMLInputElement).value;
    const date = (document.getElementById('correction-date') as HTMLInputElement).value;
    const checkInTime = (document.getElementById('correction-checkin') as HTMLInputElement).value;
    const checkOutTime = (document.getElementById('correction-checkout') as HTMLInputElement).value;
    const reason = (document.getElementById('correction-reason') as HTMLTextAreaElement).value;

    if (!checkInTime || !checkOutTime || !reason) {
      alert('Todos los campos son requeridos');
      return;
    }

    const checkIn = `${date}T${checkInTime}:00`;
    const checkOut = `${date}T${checkOutTime}:00`;

    try {
      const response = await fetch(`${(window as any).API_URL || 'http://localhost:8082'}/api/admin/attendances/${attendanceId}/correct`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          date: date,
          check_in: checkIn,
          check_out: checkOut,
          correction_reason: reason
        })
      });

      if (!response.ok) {
        const err = await response.json();
        throw new Error(err.message || 'Error al corregir');
      }

      closeCorrectionModal();
      alert('Asistencia corregida correctamente');
      loadReport();
    } catch (e: any) {
      alert(e.message || 'Error al corregir asistencia');
    }
  });

  document.getElementById('close-correction').addEventListener('click', closeCorrectionModal);
  document.getElementById('cancel-correction').addEventListener('click', closeCorrectionModal);
  correctionModal.addEventListener('click', (e) => {
    if (e.target === correctionModal) closeCorrectionModal();
  });

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      currentTab = tab.getAttribute('data-tab');
      loadReport();
    });
  });

  document.getElementById('apply-filters').addEventListener('click', loadReport);

  init();
</script>

<style>
  code {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    background: var(--color-surface-2);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
  }

  .checkbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: var(--space-3);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
</style>
