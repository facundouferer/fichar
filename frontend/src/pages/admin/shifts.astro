---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout>
  <div class="page">
    <header class="page-header">
      <div>
        <h1 class="page-title">Turnos</h1>
        <p class="page-subtitle">Gestionar horarios de trabajo</p>
      </div>
      <button class="btn btn-primary" id="add-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo turno
      </button>
    </header>

    <div class="table-wrap">
      <table class="table">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Hora inicio</th>
            <th>Hora fin</th>
            <th>Horas esperadas</th>
            <th aria-label="Acciones"></th>
          </tr>
        </thead>
        <tbody id="shifts-tbody">
          <tr><td colspan="5" class="loading-cell">Cargando…</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="modal-overlay" id="modal">
    <div class="modal" role="dialog" aria-labelledby="modal-title">
      <header class="modal-header">
        <h2 class="modal-title" id="modal-title">Nuevo turno</h2>
        <button class="modal-close" id="close-modal" aria-label="Cerrar">&times;</button>
      </header>
      <form id="shift-form" class="modal-form">
        <input type="hidden" id="shift-id" />

        <div class="form-group">
          <label for="name">Nombre</label>
          <input type="text" id="name" required placeholder="Ej: Mañana, Tarde" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="start_time">Hora inicio</label>
            <input type="time" id="start_time" required />
          </div>
          <div class="form-group">
            <label for="end_time">Hora fin</label>
            <input type="time" id="end_time" required />
          </div>
        </div>

        <div class="form-group">
          <label for="expected_hours">Horas esperadas</label>
          <input type="number" id="expected_hours" required min="1" max="24" step="0.5" />
        </div>

        <footer class="modal-actions">
          <button type="button" class="btn btn-secondary" id="cancel-btn">Cancelar</button>
          <button type="submit" class="btn btn-primary">Guardar</button>
        </footer>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  import { api, auth } from '../../config/api';

  const modal = document.getElementById('modal');
  const form = document.getElementById('shift-form') as HTMLFormElement;
  const tbody = document.getElementById('shifts-tbody');

  let shifts: any[] = [];

  async function loadShifts() {
    const token = auth.getToken();
    if (!token) return;

    try {
      shifts = await api.getShifts(token);
      renderTable();
    } catch (e) {
      tbody.innerHTML = `<tr><td colspan="5" class="error-cell">Error al cargar turnos</td></tr>`;
    }
  }

  function renderTable() {
    if (shifts.length === 0) {
      tbody.innerHTML = `<tr><td colspan="5" class="empty-cell">No hay turnos</td></tr>`;
      return;
    }

    tbody.innerHTML = shifts.map(s => `
      <tr>
        <td><strong>${s.name}</strong></td>
        <td>${s.start_time}</td>
        <td>${s.end_time}</td>
        <td>${s.expected_hours}h</td>
        <td>
          <div class="actions">
            <button class="btn-icon is-edit" data-id="${s.id}" aria-label="Editar">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
            </button>
            <button class="btn-icon is-delete" data-id="${s.id}" aria-label="Eliminar">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    tbody.querySelectorAll('.is-edit').forEach(btn => btn.addEventListener('click', () => editShift(btn.getAttribute('data-id'))));
    tbody.querySelectorAll('.is-delete').forEach(btn => btn.addEventListener('click', () => deleteShift(btn.getAttribute('data-id'))));
  }

  function openModal(shift?: any) {
    const title = document.getElementById('modal-title');
    const idInput = document.getElementById('shift-id') as HTMLInputElement;

    if (shift) {
      title.textContent = 'Editar turno';
      idInput.value = shift.id;
      (document.getElementById('name') as HTMLInputElement).value = shift.name;
      (document.getElementById('start_time') as HTMLInputElement).value = shift.start_time;
      (document.getElementById('end_time') as HTMLInputElement).value = shift.end_time;
      (document.getElementById('expected_hours') as HTMLInputElement).value = shift.expected_hours.toString();
    } else {
      title.textContent = 'Nuevo turno';
      form.reset();
      idInput.value = '';
    }
    modal.classList.add('active');
  }

  function closeModal() { modal.classList.remove('active'); }

  async function deleteShift(id: string | null) {
    if (!confirm('¿Eliminar este turno?')) return;
    const token = auth.getToken();
    if (!token) return;
    try {
      await api.deleteShift(token, id);
      await loadShifts();
    } catch (e) { alert('Error al eliminar'); }
  }

  function editShift(id: string | null) {
    const shift = shifts.find(s => s.id === id);
    if (shift) openModal(shift);
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const token = auth.getToken();
    if (!token) return;

    const id = (document.getElementById('shift-id') as HTMLInputElement).value;
    const data = {
      name: (document.getElementById('name') as HTMLInputElement).value,
      start_time: (document.getElementById('start_time') as HTMLInputElement).value,
      end_time: (document.getElementById('end_time') as HTMLInputElement).value,
      expected_hours: parseFloat((document.getElementById('expected_hours') as HTMLInputElement).value),
    };

    try {
      if (id) await api.updateShift(token, id, data);
      else await api.createShift(token, data);
      closeModal();
      await loadShifts();
    } catch (err: any) { alert(err.message || 'Error'); }
  });

  document.getElementById('add-btn').addEventListener('click', () => openModal());
  document.getElementById('close-modal').addEventListener('click', closeModal);
  document.getElementById('cancel-btn').addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  loadShifts();
</script>
