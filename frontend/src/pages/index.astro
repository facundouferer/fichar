---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fichar - Registro de Asistencia">
  <main class="container">
    <div class="logo">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
    </div>
    
    <h1 class="title">Fichar</h1>
    <p class="subtitle">Sistema de Control de Asistencia</p>

    <div class="clock-in-card">
      <form id="check-form" class="check-form">
        <div class="input-group">
          <label for="dni" class="input-label">Ingrese su DNI</label>
          <input 
            type="text" 
            id="dni" 
            name="dni" 
            class="input-field"
            placeholder="Ej: 12345678"
            required
            autocomplete="off"
            inputmode="numeric"
            pattern="[0-9]+"
          />
        </div>
        
        <button type="submit" class="submit-btn" id="submit-btn">
          <span class="btn-text">Registrar</span>
          <span class="btn-loading" style="display: none;">Registrando...</span>
        </button>
      </form>

      <div id="result" class="result" style="display: none;"></div>
    </div>

    <div class="auth-link">
      <a href="/login" class="link">¿Es empleado? Iniciar sesión</a>
    </div>
  </main>
</Layout>

<script>
  import { api } from '../config/api';

  const form = document.getElementById('check-form') as HTMLFormElement;
  const dniInput = document.getElementById('dni') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resultDiv = document.getElementById('result') as HTMLDivElement;

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    const btnText = submitBtn.querySelector('.btn-text') as HTMLSpanElement;
    const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLSpanElement;
    btnText.style.display = loading ? 'none' : 'inline';
    btnLoading.style.display = loading ? 'inline' : 'none';
  }

  function showResult(success: boolean, message: string, operation?: string) {
    resultDiv.style.display = 'block';
    resultDiv.className = 'result ' + (success ? 'success' : 'error');
    
    const icon = success ? '✓' : '✕';
    const actionText = operation === 'check_in' ? 'Entrada' : 'Salida';
    
    resultDiv.innerHTML = `
      <div class="result-icon">${icon}</div>
      <div class="result-text">${message}</div>
      ${operation ? `<div class="result-operation">${actionText}</div>` : ''}
    `;
    
    // Auto-hide after 5 seconds
    setTimeout(() => {
      resultDiv.style.display = 'none';
    }, 5000);
  }

  // Get user's GPS coordinates
  async function getLocation(): Promise<{ latitude: number; longitude: number }> {
    return new Promise((resolve, reject) => {
      if (!navigator.geolocation) {
        reject(new Error('Su navegador no soporta geolocalización'));
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          resolve({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
          });
        },
        (error) => {
          let message: string;
          switch (error.code) {
            case error.PERMISSION_DENIED:
              message = 'Se requiere ubicación para registrar asistencia. Por favor permita el acceso a su ubicación.';
              break;
            case error.POSITION_UNAVAILABLE:
              message = 'Ubicación no disponible en este dispositivo';
              break;
            case error.TIMEOUT:
              message = 'Tiempo de espera para obtener ubicación agotado';
              break;
            default:
              message = 'Error al obtener ubicación';
          }
          reject(new Error(message));
        },
        {
          timeout: 10000,
          enableHighAccuracy: true,
          maximumAge: 0,
        }
      );
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const dni = dniInput.value.trim();
    if (!dni) return;

    setLoading(true);
    resultDiv.style.display = 'none';

    try {
      // Request GPS location first
      const location = await getLocation();
      
      // Submit with location data
      const response = await api.checkAttendance(dni, location.latitude, location.longitude);
      showResult(true, response.message, response.operation);
      dniInput.value = '';
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Error desconocido';
      showResult(false, message);
    } finally {
      setLoading(false);
    }
  });
</script>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 1.5rem;
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    min-height: 100dvh;
  }

  .logo {
    color: #3b82f6;
    margin-bottom: 1rem;
  }

  .title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    color: #1e293b;
    letter-spacing: -0.025em;
  }

  .subtitle {
    font-size: 1rem;
    color: #64748b;
    margin: 0.5rem 0 2rem;
  }

  .clock-in-card {
    background: white;
    border-radius: 1rem;
    padding: 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
  }

  .check-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .input-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #374151;
  }

  .input-field {
    padding: 0.875rem 1rem;
    border: 2px solid #e5e7eb;
    border-radius: 0.5rem;
    font-size: 1.125rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  .input-field:focus {
    outline: none;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  .input-field::placeholder {
    color: #9ca3af;
  }

  .submit-btn {
    padding: 0.875rem 1.5rem;
    background: #3b82f6;
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
  }

  .submit-btn:hover:not(:disabled) {
    background: #2563eb;
  }

  .submit-btn:active:not(:disabled) {
    transform: scale(0.98);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .result {
    margin-top: 1.5rem;
    padding: 1rem;
    border-radius: 0.5rem;
    text-align: center;
    animation: fadeIn 0.3s ease-out;
  }

  .result.success {
    background: #ecfdf5;
    border: 1px solid #10b981;
    color: #065f46;
  }

  .result.error {
    background: #fef2f2;
    border: 1px solid #ef4444;
    color: #991b1b;
  }

  .result-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .result-text {
    font-weight: 500;
  }

  .result-operation {
    font-size: 0.875rem;
    opacity: 0.8;
    margin-top: 0.25rem;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .auth-link {
    margin-top: 1.5rem;
  }

  .link {
    color: #3b82f6;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .link:hover {
    text-decoration: underline;
  }
</style>