---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fichar - Registro de Asistencia">
  <main class="container">
    <h1 class="hero">Fichar</h1>
    <p class="subtitle">Sistema de registro de ingreso y egreso</p>
  </main>
</Layout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
  }

  .hero {
    font-size: 4rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #2563eb;
  }

  .subtitle {
    font-size: 1.5rem;
    color: #64748b;
  }
</style>
