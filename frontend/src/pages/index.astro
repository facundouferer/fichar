---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Fichar — Registro de Asistencia">
  <main class="page">
    <div class="card">
      <header class="card-head">
        <div class="brand">
          <div class="brand-mark" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <span class="brand-name">Fichar</span>
        </div>
        <h1 class="title">Registrar asistencia</h1>
        <p class="subtitle">Ingresá tu DNI para fichar entrada o salida.</p>
      </header>

      <form id="check-form" class="check-form" novalidate>
        <div class="form-group">
          <label for="dni">DNI</label>
          <input
            type="text"
            id="dni"
            name="dni"
            class="input input-lg"
            placeholder="20123456"
            required
            autocomplete="off"
            inputmode="numeric"
            pattern="[0-9]+"
          />
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="submit-btn">
          <span class="btn-text">Registrar</span>
          <span class="btn-loading" hidden>
            <span class="spinner spinner-on-accent" aria-hidden="true"></span>
            Registrando…
          </span>
        </button>

        <div id="result" class="result" hidden></div>
      </form>

      <footer class="card-foot">
        <a href="/login" class="link-muted">¿Sos empleado? Iniciar sesión →</a>
      </footer>
    </div>
  </main>
</Layout>

<script>
  import { api } from '../config/api';

  const form = document.getElementById('check-form') as HTMLFormElement;
  const dniInput = document.getElementById('dni') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resultDiv = document.getElementById('result') as HTMLDivElement;

  function setLoading(loading: boolean) {
    submitBtn.disabled = loading;
    const btnText = submitBtn.querySelector('.btn-text') as HTMLSpanElement;
    const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLSpanElement;
    btnText.hidden = loading;
    btnLoading.hidden = !loading;
  }

  function showResult(success: boolean, message: string, operation?: string) {
    resultDiv.hidden = false;
    resultDiv.className = 'result ' + (success ? 'is-success' : 'is-error');

    const icon = success ? '✓' : '✕';
    const actionText = operation === 'check_in' ? 'Entrada' : 'Salida';

    resultDiv.innerHTML = `
      <div class="result-icon">${icon}</div>
      <div class="result-text">${message}</div>
      ${operation ? `<div class="result-operation">${actionText}</div>` : ''}
    `;

    setTimeout(() => { resultDiv.hidden = true; }, 5000);
  }

  async function getLocation(): Promise<{ latitude: number; longitude: number }> {
    return new Promise((resolve, reject) => {
      if (!navigator.geolocation) {
        reject(new Error('Su navegador no soporta geolocalización'));
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          resolve({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
          });
        },
        (error) => {
          let message: string;
          switch (error.code) {
            case error.PERMISSION_DENIED:
              message = 'Se requiere ubicación para registrar asistencia. Por favor permita el acceso a su ubicación.';
              break;
            case error.POSITION_UNAVAILABLE:
              message = 'Ubicación no disponible en este dispositivo';
              break;
            case error.TIMEOUT:
              message = 'Tiempo de espera para obtener ubicación agotado';
              break;
            default:
              message = 'Error al obtener ubicación';
          }
          reject(new Error(message));
        },
        { timeout: 10000, enableHighAccuracy: true, maximumAge: 0 }
      );
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const dni = dniInput.value.trim();
    if (!dni) return;

    setLoading(true);
    resultDiv.hidden = true;

    try {
      const location = await getLocation();
      const response = await api.checkAttendance(dni, location.latitude, location.longitude);
      showResult(true, response.message, response.operation);
      dniInput.value = '';
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Error desconocido';
      showResult(false, message);
    } finally {
      setLoading(false);
    }
  });
</script>

<style>
  .page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: var(--space-6);
    background:
      radial-gradient(circle at 20% 0%, rgba(94, 106, 210, 0.06), transparent 40%),
      radial-gradient(circle at 80% 100%, rgba(94, 106, 210, 0.04), transparent 50%),
      var(--color-bg);
  }

  .card {
    width: 100%;
    max-width: 420px;
    padding: var(--space-8);
    border-radius: var(--radius-xl);
  }

  .card-head {
    margin-bottom: var(--space-6);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .brand-mark {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: var(--color-accent);
    color: var(--color-fg-on-accent);
    border-radius: var(--radius-md);
  }

  .brand-name {
    font-size: var(--text-md);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--color-fg);
  }

  .title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-2);
  }

  .subtitle {
    font-size: var(--text-md);
    color: var(--color-fg-muted);
    line-height: var(--leading-snug);
  }

  .check-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .input-lg {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-lg);
    font-variant-numeric: tabular-nums;
  }

  .btn-block {
    width: 100%;
    padding: var(--space-3) var(--space-5);
  }

  .spinner-on-accent {
    border-color: rgba(255, 255, 255, 0.3);
    border-top-color: var(--color-fg-on-accent);
  }

  .btn-loading {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .result {
    padding: var(--space-4);
    text-align: center;
    border: 1px solid;
    border-radius: var(--radius-md);
    animation: slide-in var(--duration-base) var(--ease-out);
  }

  .result.is-success {
    background: var(--color-success-bg);
    border-color: var(--color-success-border);
    color: var(--color-success-fg);
  }

  .result.is-error {
    background: var(--color-danger-bg);
    border-color: var(--color-danger-border);
    color: var(--color-danger-fg);
  }

  .result-icon {
    font-size: var(--text-2xl);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .result-text {
    font-weight: var(--weight-medium);
  }

  .result-operation {
    font-size: var(--text-sm);
    opacity: 0.85;
    margin-top: var(--space-1);
  }

  @keyframes slide-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card-foot {
    margin-top: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .link-muted {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
  }

  .link-muted:hover {
    color: var(--color-fg);
  }

  @media (max-width: 480px) {
    .card {
      padding: var(--space-6);
    }
  }
</style>
